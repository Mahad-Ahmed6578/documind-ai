# ─── Database ───────────────────────────────────────────────
# Local dev: SQLite (file-based, zero config)
# DATABASE_URL=file:./db/custom.db

# Production (Vercel): use Supabase PostgreSQL
DATABASE_URL=postgresql://user:password@host:6543/postgres

# ─── LLM Provider (chat responses) ──────────────────────────
#   - "zai"        (default) — Z.ai GLM-4, free, auto-configured
#   - "gemini"               — Google Gemini, requires GEMINI_API_KEY
#   - "openrouter"           — OpenRouter (200+ models), requires OPENROUTER_API_KEY
LLM_PROVIDER=openrouter

# ─── OpenRouter Configuration ───────────────────────────────
#   Get your API key from https://openrouter.ai/keys
#   Browse models at https://openrouter.ai/models
OPENROUTER_API_KEY=your-openrouter-api-key-here
OPENROUTER_MODEL=z-ai/glm-4.5-air:free
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# ─── Embedding Provider (text → vectors) ────────────────────
#   - "tfidf"  (default) — TF-IDF + feature hashing (256-dim), no API
#   - "glm4"             — GLM-4 Semantic: bigrams + char n-grams (512-dim), no API
#   - "gemini"           — Google text-embedding-004 (768-dim), requires GEMINI_API_KEY
EMBED_PROVIDER=gemini

# ─── Vector Store Provider (where to store/search vectors) ──
#   - "memory"   (default) — in-memory via Prisma (loads all chunks per query)
#   - "pinecone"           — Pinecone managed vector database (production-grade)
VECTOR_STORE_PROVIDER=pinecone

# ─── Google Gemini API Key (required for EMBED_PROVIDER=gemini) ───
GEMINI_API_KEY=your-gemini-api-key-here
GOOGLE_API_KEY=your-gemini-api-key-here

# ─── Pinecone Configuration (required for VECTOR_STORE_PROVIDER=pinecone) ───
PINECONE_API_KEY=your-pinecone-api-key-here
PINECONE_INDEX=documind-ai-index
PINECONE_ENVIRONMENT=us-east-1

# ─── Model Selection (optional) ────────────────────────────
GEMINI_CHAT_MODEL=gemini-2.0-flash
GEMINI_EMBED_MODEL=text-embedding-004
